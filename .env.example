# =========================================================================
# 音声日記PWA 環境変数サンプル
# このファイルをコピーして .env.local を作り、実際の値を入れてください。
#   cp .env.example .env.local
# Vercel では「Settings → Environment Variables」に同じキーを登録します。
# .env / .env.local は絶対にコミットしないでください（.gitignore 済み）。
# =========================================================================

# --- OpenAI ---------------------------------------------------------------
# OpenAI の API キー。必ずサーバーサイドでのみ使用され、クライアントへは公開されません。
# （NEXT_PUBLIC_ を付けないこと！付けるとブラウザに漏れます）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 日記本文を生成するチャットモデル。未設定時は gpt-4o-mini。
OPENAI_MODEL=gpt-4o-mini

# 音声文字起こしモデル。未設定時は gpt-4o-mini-transcribe。
# 例: gpt-4o-mini-transcribe / gpt-4o-transcribe / whisper-1
TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# --- 認証 -----------------------------------------------------------------
# アプリを開くためのパスワード（あなただけが知る文字列）。
APP_PASSWORD=change-me-to-a-long-random-passphrase

# Cookie 署名用のシークレット。32文字以上のランダム文字列を推奨。
# 例: openssl rand -hex 32 で生成
AUTH_SECRET=please-generate-a-long-random-secret-at-least-32-chars

# ログインセッションの有効日数（未設定時は 30 日）。
SESSION_DAYS=30

# --- 制限（任意） ---------------------------------------------------------
# アップロード可能な音声ファイルの最大サイズ（バイト）。未設定時は 25MB。
MAX_AUDIO_BYTES=26214400
