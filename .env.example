# =========================================================================
# 音声日記PWA 環境変数サンプル
# このファイルをコピーして .env.local を作り、実際の値を入れてください。
#   cp .env.example .env.local
# Vercel では「Settings → Environment Variables」に同じキーを登録します。
# .env / .env.local は絶対にコミットしないでください（.gitignore 済み）。
#
# Gemini APIキーはユーザーごとに違うため、ここには含まれません。
# サインアップ後、アプリの設定画面から各自のキーを登録します。
# =========================================================================

# --- 認証 -----------------------------------------------------------------
# Cookie 署名用のシークレット。32文字以上のランダム文字列を推奨。
# 例: openssl rand -hex 32 で生成
AUTH_SECRET=please-generate-a-long-random-secret-at-least-32-chars

# ログインセッションの有効日数（未設定時は 30 日）。
SESSION_DAYS=30

# --- アカウント（招待制） --------------------------------------------------
# 新規登録時に必要な招待コード。共有したい相手にだけこの文字列を伝える。
INVITE_CODE=change-me-to-a-shared-invite-phrase

# アカウントに保存するGemini APIキーの暗号化(AES-256-GCM)に使う鍵。
# base64エンコードされた32バイトが必要。
# 例: openssl rand -base64 32 で生成
ACCOUNT_ENCRYPTION_KEY=change-me-to-a-base64-encoded-32-byte-key

# --- アカウント保存用データベース（Upstash Redis） -------------------------
# VercelのMarketplace統合（Storage → Upstash for Redis）を追加すると
# 自動で注入される値。ローカル開発時はUpstashのダッシュボードから
# 取得した値、またはVercelの `vercel env pull .env.development.local`
# で取得した値を使う。
KV_REST_API_URL=https://xxxxx.upstash.io
KV_REST_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Gemini モデル（任意） --------------------------------------------------
# 日記本文を生成するモデル。未設定時は gemini-3.1-flash-lite。
# （gemini-2.0-flash系は2026-06-01付けで廃止済み。モデル名はGoogle側の
#   提供状況により変わることがあるため、429エラーが出る場合はAI Studioの
#   使用状況ページ https://ai.dev/rate-limit で現在の推奨モデルを確認してください）
GEMINI_MODEL=gemini-3.1-flash-lite

# 音声文字起こしに使うモデル。未設定時は gemini-3.1-flash-lite。
GEMINI_TRANSCRIBE_MODEL=gemini-3.1-flash-lite

# --- 制限（任意） ---------------------------------------------------------
# 1リクエストあたりの音声アップロード上限（バイト）。未設定時は 4MB。
# Vercelのサーバーレス関数はリクエストボディに約4.5MBのプラットフォーム上限が
# あるため、それより大きい値に増やしても届く前に拒否される。これより大きい
# 音声は、アプリ側が自動でチャンク分割してから複数リクエストで送信する。
MAX_AUDIO_BYTES=4194304
