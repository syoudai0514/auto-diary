# =========================================================================
# 音声日記PWA 環境変数サンプル
# このファイルをコピーして .env.local を作り、実際の値を入れてください。
#   cp .env.example .env.local
# Vercel では「Settings → Environment Variables」に同じキーを登録します。
# .env / .env.local は絶対にコミットしないでください（.gitignore 済み）。
# =========================================================================

# --- Google Gemini（無料枠あり） -------------------------------------------
# Google AI Studio (https://aistudio.google.com/apikey) で無料発行できるAPIキー。
# 必ずサーバーサイドでのみ使用され、クライアントへは公開されません。
# （NEXT_PUBLIC_ を付けないこと！付けるとブラウザに漏れます）
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 日記本文を生成するモデル。未設定時は gemini-2.0-flash。
GEMINI_MODEL=gemini-2.0-flash

# 音声文字起こしに使うモデル。未設定時は gemini-2.0-flash。
GEMINI_TRANSCRIBE_MODEL=gemini-2.0-flash

# --- 認証 -----------------------------------------------------------------
# アプリを開くためのパスワード（あなただけが知る文字列）。
APP_PASSWORD=change-me-to-a-long-random-passphrase

# Cookie 署名用のシークレット。32文字以上のランダム文字列を推奨。
# 例: openssl rand -hex 32 で生成
AUTH_SECRET=please-generate-a-long-random-secret-at-least-32-chars

# ログインセッションの有効日数（未設定時は 30 日）。
SESSION_DAYS=30

# --- 制限（任意） ---------------------------------------------------------
# アップロード可能な音声ファイルの最大サイズ（バイト）。未設定時は 15MB。
# Gemini へは音声を base64 のインラインデータとして送るため、
# 保守的な既定値にしている（無料枠のリクエストサイズ制限に配慮）。
MAX_AUDIO_BYTES=15728640
